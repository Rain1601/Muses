# =============================================
# Muses — Google Cloud Run Production Config
# =============================================
# Copy this file, fill in values, and pass to Cloud Run as env vars.
# DO NOT commit the filled version to git.

# ===== Backend (Cloud Run Service: muses-backend) =====

ENVIRONMENT=production
DEBUG=False
HOST=0.0.0.0
PORT=8080

# Public URL of this backend (used for OAuth redirect etc.)
BACKEND_URL=https://muses-backend-XXXXX.run.app

# Frontend URL (used for CORS + OAuth redirect after login)
# Multiple origins can be comma-separated
FRONTEND_URL=https://muses-frontend-XXXXX.run.app

# --- Database (Cloud SQL PostgreSQL) ---
# Unix socket format for Cloud SQL Proxy (recommended):
DATABASE_URL=postgresql://USER:PASSWORD@/muses?host=/cloudsql/PROJECT_ID:REGION:INSTANCE_NAME
# Or TCP format if using public IP:
# DATABASE_URL=postgresql://USER:PASSWORD@IP:5432/muses

# --- GitHub OAuth ---
# Create a new OAuth App at https://github.com/settings/developers
# Callback URL: ${BACKEND_URL}/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Google OAuth ---
# GCP Console → APIs & Services → Credentials → Create OAuth Client ID
# Callback URL: ${BACKEND_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Security ---
JWT_SECRET=<generate: python3 -c "import secrets; print(secrets.token_hex(32))">
ENCRYPTION_KEY=<generate: python3 -c "import secrets; print(secrets.token_hex(32))">
ENCRYPTION_SALT=muses_production_salt

# --- AI APIs ---
OPENAI_API_KEY=
AIHUBMIX_API_KEY=
AIHUBMIX_BASE_URL=https://aihubmix.com/v1

# --- Studio (disabled for Cloud Run — needs local filesystem) ---
ENABLE_STUDIO=false

# ===== Frontend (Cloud Run Service: muses-frontend) =====

# Baked into client JS at build time
NEXT_PUBLIC_API_URL=https://muses-backend-XXXXX.run.app

# Server-side rewrite target (same as NEXT_PUBLIC_API_URL for Cloud Run)
BACKEND_INTERNAL_URL=https://muses-backend-XXXXX.run.app
